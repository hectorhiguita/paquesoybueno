{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000"],
      "settings": {
        "preset": "perf",
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.7}],
        "categories:accessibility": ["error", {"minScore": 0.85}]
      }
    }
  }
}
